---
const links = [
  { label: '@MelucaNUAA', href: 'https://github.com/MelucaNUAA', icon: 'github' },
  { label: 'nuaalhd@163.com', href: 'mailto:nuaalhd@163.com', icon: 'mail' },
];
---

<aside class="sidebar hidden lg:block">
  <div class="sidebar-card">
    <div class="sidebar-avatar">✦</div>
    <div class="sidebar-name">beautifugly</div>
    <p class="sidebar-bio">技术学习 · AI 创作 · 有趣项目</p>

    <div class="sidebar-divider"></div>

    <div class="sidebar-links">
      {links.map(link => (
        <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel="noopener" class="sidebar-link">
          {link.icon === 'github' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          )}
          {link.icon === 'mail' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          )}
          <span>{link.label}</span>
        </a>
      ))}
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-tech">
      {['Astro', 'Tailwind', 'TypeScript'].map(t => (
        <span class="sidebar-tag">{t}</span>
      ))}
    </div>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    left: max(calc((100vw - 80rem) / 2 - 220px), 16px);
    top: 50%;
    transform: translateY(-50%);
    width: 200px;
    z-index: 40;
  }

  .sidebar-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 24px 20px;
    box-shadow: 0 4px 20px var(--color-shadow);
    text-align: center;
  }

  .sidebar-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin: 0 auto 12px;
  }

  .sidebar-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 6px;
  }

  .sidebar-bio {
    font-size: 0.72rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .sidebar-divider {
    height: 1px;
    background: var(--color-border);
    margin: 14px 0;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 0.78rem;
    color: var(--color-text-light);
    transition: color 0.2s;
    text-decoration: none;
  }

  .sidebar-link:hover {
    color: var(--color-accent);
  }

  .sidebar-tech {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
  }

  .sidebar-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: var(--color-accent-secondary);
    color: #fff;
    border-radius: 9999px;
  }
</style>
