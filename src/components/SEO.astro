---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  tags?: string[];
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  publishDate,
  tags = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const structuredData = type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: imageURL.href,
  datePublished: publishDate?.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Beautifugly',
    url: 'https://beautifugly.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Beautifugly',
    url: 'https://beautifugly.com',
  },
  mainEntityOfPage: canonicalURL.href,
} : {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Beautifugly',
  url: 'https://beautifugly.com',
  description: '技术博文、AI 创作、有趣项目 — 一个记录成长与探索的小站。',
};
---

<!-- Primary Meta Tags -->
<meta name="title" content={`${title} | Beautifugly`} />
<meta name="description" content={description} />
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
<link rel="canonical" href={canonicalURL.href} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={`${title} | Beautifugly`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL.href} />
<meta property="og:site_name" content="Beautifugly" />
<meta property="og:locale" content="zh_CN" />
{publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
{tags.map(tag => <meta property="article:tag" content={tag} />)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL.href} />
<meta property="twitter:title" content={`${title} | Beautifugly`} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL.href} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
