---
const year = new Date().getFullYear();
---

<footer class="mt-16 relative">
  {/* Decorative top border with gradient */}
  <div class="h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/30 to-transparent" />

  <div class="layout-band py-10">
    <div class="flex flex-col items-center gap-6">

      {/* Brand */}
      <a href="/" class="font-[var(--font-heading)] text-sm tracking-wider text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
        ✦ beautifugly
      </a>

      {/* Stats */}
      <div class="footer-stats">
        <span class="footer-stats-icon">👁</span>
        <span id="busuanzi_container_site_pv" class="footer-stats-item"><span id="busuanzi_value_site_pv">--</span> 次浏览</span>
        <span class="footer-stats-dot">·</span>
        <span class="footer-stats-icon">👤</span>
        <span id="busuanzi_container_site_uv" class="footer-stats-item"><span id="busuanzi_value_site_uv">--</span> 位访客</span>
      </div>

      {/* Links */}
      <div class="flex items-center gap-5">
        <a href="/blog" class="text-xs text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">博客</a>
        <a href="/works" class="text-xs text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">作品</a>
        <a href="/projects" class="text-xs text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">项目</a>
        <span class="text-[var(--color-border)]">|</span>
        <a href="https://github.com/MelucaNUAA" target="_blank" rel="noopener" class="text-[var(--color-text-light)] hover:text-[var(--color-text)] transition-colors" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="/rss.xml" target="_blank" rel="noopener" class="text-[var(--color-text-light)] hover:text-[var(--color-text)] transition-colors" aria-label="RSS">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>
          </svg>
        </a>
      </div>

      {/* Copyright */}
      <p class="text-xs text-[var(--color-text-light)] opacity-60">
        © {year} · Made with ✦ · Vibe Coding
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-light);
    white-space: nowrap;
  }

  .footer-stats-icon {
    font-size: 0.8rem;
    line-height: 1;
  }

  .footer-stats-dot {
    color: var(--color-border);
  }

  .footer-stats-item {
    tabular-nums: true;
  }
</style>
