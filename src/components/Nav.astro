---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '博客' },
  { href: '/works', label: '作品' },
  { href: '/projects', label: '项目', children: [
    { href: '/projects', label: '全部项目' },
    { href: '/projects/ai-image', label: 'AI 生图' },
  ]},
  { href: '/about', label: '关于' },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav-bar">
  <div class="nav-inner">
    {/* Left: Logo */}
    <a href="/" class="nav-logo">
      ✦ beautifugly
    </a>

    {/* Center: Desktop nav links */}
    <div class="nav-links">
      {links.map(link => (
        link.children ? (
          <div class="nav-dropdown">
            <a
              href={link.href}
              class:list={[
                'nav-link',
                currentPath.startsWith(link.href) && 'active',
              ]}
              aria-haspopup="true"
              aria-expanded="false"
            >
              <span class="nav-link-text">{link.label}</span>
              <svg class="nav-chevron" width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 5l3 3 3-3"/>
              </svg>
            </a>
            <div class="nav-dropdown-menu" role="menu">
              <div class="nav-dropdown-inner">
                {link.children.map(child => (
                  <a
                    href={child.href}
                    class:list={[
                      'nav-dropdown-item',
                      currentPath === child.href && 'active',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'nav-link',
              currentPath === link.href && 'active',
            ]}
          >
            <span class="nav-link-text">{link.label}</span>
          </a>
        )
      ))}
    </div>

    {/* Right: Controls */}
    <div class="nav-controls">
      <button id="search-btn" class="nav-icon-btn" aria-label="搜索">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
      </button>
      <ThemeToggle />
    </div>

    {/* Mobile controls */}
    <div class="nav-mobile-controls">
      <button id="search-btn-mobile" class="nav-icon-btn" aria-label="搜索">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
      </button>
      <ThemeToggle />
      <button id="menu-toggle" class="nav-icon-btn" aria-label="菜单">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile menu */}
  <div id="mobile-menu" class="nav-mobile-menu">
    <div class="nav-mobile-menu-inner">
      {links.map(link => (
        link.children ? (
          <div>
            <a
              href={link.href}
              class:list={[
                'nav-mobile-link',
                currentPath.startsWith(link.href) && 'active',
              ]}
            >
              {link.label}
            </a>
            <div class="nav-mobile-sub">
              {link.children.map(child => (
                <a
                  href={child.href}
                  class:list={[
                    'nav-mobile-link sub',
                    currentPath === child.href && 'active',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'nav-mobile-link',
              currentPath === link.href && 'active',
            ]}
          >
            {link.label}
          </a>
        )
      ))}
    </div>
  </div>
</nav>

{/* Search modal */}
<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="搜索">
  <div class="absolute inset-0 bg-black/50" id="search-overlay"></div>
  <div class="relative max-w-2xl mx-auto mt-20 px-4 max-h-[80vh] overflow-y-auto">
    <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-lg p-4 shadow-xl">
      <input
        id="search-input"
        type="text"
        placeholder="搜索文章、作品、项目..."
        class="w-full bg-transparent text-[var(--color-text)] placeholder-[var(--color-text-light)] outline-none text-lg"
        autofocus
      />
      <div id="search-results" class="mt-4 max-h-80 overflow-y-auto"></div>
      <div class="mt-3 text-xs text-[var(--color-text-light)] text-center">
        按 ESC 关闭 · Ctrl+K 打开
      </div>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('open');
  });

  // Search functionality
  const searchModal = document.getElementById('search-modal');
  const searchOverlay = document.getElementById('search-overlay');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results');
  const searchBtn = document.getElementById('search-btn');
  const searchBtnMobile = document.getElementById('search-btn-mobile');

  interface SearchItem {
    title: string;
    description: string;
    url: string;
    tags: string[];
  }

  let searchData: SearchItem[] = [];

  async function loadSearchData() {
    if (searchData.length > 0) return;
    try {
      const res = await fetch('/api/search.json');
      searchData = await res.json();
    } catch {
      searchData = [];
    }
  }

  function openSearch() {
    searchModal?.classList.remove('hidden');
    searchInput?.focus();
    loadSearchData();
  }

  function closeSearch() {
    searchModal?.classList.add('hidden');
    if (searchInput) searchInput.value = '';
    if (searchResults) {
      while (searchResults.firstChild) {
        searchResults.removeChild(searchResults.firstChild);
      }
    }
  }

  searchBtn?.addEventListener('click', openSearch);
  searchBtnMobile?.addEventListener('click', openSearch);
  searchOverlay?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape') {
      closeSearch();
    }
  });

  function createResultItem(item: SearchItem): HTMLAnchorElement {
    const a = document.createElement('a');
    a.href = item.url;
    a.className = 'block p-3 rounded hover:bg-[var(--color-border)] transition-colors';

    const titleDiv = document.createElement('div');
    titleDiv.className = 'font-medium text-sm';
    titleDiv.textContent = item.title;

    const descDiv = document.createElement('div');
    descDiv.className = 'text-xs text-[var(--color-text-light)] mt-1';
    descDiv.textContent = item.description || '';

    const tagsDiv = document.createElement('div');
    tagsDiv.className = 'flex gap-1 mt-1';
    item.tags.forEach(t => {
      const span = document.createElement('span');
      span.className = 'text-[10px] px-1.5 py-0.5 bg-[var(--color-accent)]/10 rounded';
      span.textContent = t;
      tagsDiv.appendChild(span);
    });

    a.appendChild(titleDiv);
    a.appendChild(descDiv);
    a.appendChild(tagsDiv);
    return a;
  }

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    if (!searchResults) return;

    while (searchResults.firstChild) {
      searchResults.removeChild(searchResults.firstChild);
    }

    if (!query) return;

    const filtered = searchData.filter(item =>
      item.title.toLowerCase().includes(query) ||
      item.description.toLowerCase().includes(query) ||
      item.tags.some(t => t.toLowerCase().includes(query))
    );

    if (filtered.length === 0) {
      const p = document.createElement('p');
      p.className = 'text-center text-[var(--color-text-light)] py-4';
      p.textContent = '没有找到相关内容';
      searchResults.appendChild(p);
      return;
    }

    filtered.forEach(item => {
      searchResults.appendChild(createResultItem(item));
    });
  });
</script>

<style>
  /* ── Nav Bar ── */
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--layout-px);
    height: 56px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  /* ── Logo ── */
  .nav-logo {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.3s;
    flex-shrink: 0;
  }
  .nav-logo:hover {
    color: var(--color-accent);
  }

  /* ── Center Links (Desktop) ── */
  .nav-links {
    display: none;
    align-items: center;
    gap: 0.25rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  /* ── Nav Link ── */
  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text-light);
    text-decoration: none;
    transition: color 0.3s;
    border-radius: 8px;
  }

  .nav-link-text {
    position: relative;
    z-index: 1;
  }

  /* Hover background glow */
  .nav-link::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .nav-link:hover::before {
    opacity: 1;
  }

  /* Animated underline */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    transform: translateX(-50%);
    transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover::after {
    width: 60%;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  /* Active state */
  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-link.active::after {
    width: 40%;
    background: var(--color-accent);
    opacity: 0.5;
  }

  /* ── Dropdown ── */
  .nav-dropdown {
    position: relative;
  }

  .nav-chevron {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.5;
  }

  .nav-dropdown:hover .nav-chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  .nav-dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 8px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s, transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateX(-50%) translateY(-4px);
  }

  .nav-dropdown:hover .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown-inner {
    background: var(--color-bg-card);
    border: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
    border-radius: 12px;
    padding: 6px;
    min-width: 140px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
  }

  .nav-dropdown-item {
    display: block;
    padding: 0.5rem 0.875rem;
    font-size: 0.82rem;
    color: var(--color-text-light);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .nav-dropdown-item:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }

  .nav-dropdown-item.active {
    color: var(--color-accent);
  }

  /* ── Controls ── */
  .nav-controls {
    display: none;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .nav-controls {
      display: flex;
    }
  }

  .nav-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: var(--color-text-light);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.25s;
  }

  .nav-icon-btn:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  /* ── Mobile Controls ── */
  .nav-mobile-controls {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .nav-mobile-controls {
      display: none;
    }
  }

  /* ── Mobile Menu ── */
  .nav-mobile-menu {
    display: none;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
    background: var(--color-bg);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-mobile-menu.open {
    max-height: 400px;
  }

  @media (min-width: 768px) {
    .nav-mobile-menu {
      display: none !important;
    }
  }

  .nav-mobile-menu-inner {
    padding: 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-mobile-link {
    display: block;
    padding: 0.625rem 0.75rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-text-light);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .nav-mobile-link:hover,
  .nav-mobile-link.active {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }

  .nav-mobile-link.sub {
    font-size: 0.82rem;
    padding-left: 1.5rem;
    font-weight: 400;
  }

  .nav-mobile-sub {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: 0.25rem;
  }
</style>
