---

---

<div class="card p-6 bg-[var(--color-accent)]/5">
  <div class="flex items-start gap-3 mb-3">
    <span class="text-xl">✉</span>
    <div>
      <h3 class="font-[var(--font-pixel)] text-xs">订阅更新</h3>
      <p class="text-sm text-[var(--color-text-light)] mt-1">获取最新文章和作品通知，不会 spam 你</p>
    </div>
  </div>
  <form class="flex gap-2 mt-4" id="newsletter-form">
    <input
      type="email"
      placeholder="your@email.com"
      required
      class="flex-1 px-4 py-2 bg-[var(--color-bg-card)] border-2 border-[var(--color-border)] rounded focus:border-[var(--color-accent)] outline-none transition-colors text-sm"
    />
    <button type="submit" class="pixel-btn bg-[var(--color-accent)] text-white text-xs shrink-0">
      订阅
    </button>
  </form>
  <p class="text-[10px] text-[var(--color-text-light)] mt-2">支持随时退订</p>
</div>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (form.querySelector('input[type="email"]') as HTMLInputElement)?.value;
    if (email) {
      // TODO: 接入邮件订阅服务 (如 Buttondown, ConvertKit, Resend)
      alert('感谢订阅！后续会通过邮件通知你最新内容。');
      form.reset();
    }
  });
</script>
