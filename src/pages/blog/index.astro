---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))];

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<Layout title="博客">
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="font-[var(--font-pixel)] text-xl mb-2">✦ 博客</h1>
    <p class="text-[var(--color-text-light)] mb-8">技术笔记、学习心得、踩坑记录</p>

    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        <button class="tag-filter active text-xs px-3 py-1.5 rounded-full border-2 border-[var(--color-border-pixel)] bg-[var(--color-accent)] text-white" data-tag="all">
          全部
        </button>
        {allTags.map(tag => (
          <button class="tag-filter text-xs px-3 py-1.5 rounded-full border-2 border-[var(--color-border)] hover:border-[var(--color-border-pixel)] transition-colors" data-tag={tag}>
            {tag}
          </button>
        ))}
      </div>
    )}

    <div class="grid gap-4" id="post-list">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="card p-5 post-item" data-tags={post.data.tags.join(',')}>
          <div class="flex flex-col md:flex-row md:items-center gap-3">
            <span class="text-xs text-[var(--color-text-light)] whitespace-nowrap">{formatDate(post.data.date)}</span>
            <span class="font-medium">{post.data.title}</span>
            <div class="flex gap-1.5 flex-wrap md:ml-auto">
              {post.data.tags.map(tag => (
                <span class="text-xs px-2 py-0.5 bg-[var(--color-accent)]/10 rounded">{tag}</span>
              ))}
            </div>
          </div>
          {post.data.description && (
            <p class="text-sm text-[var(--color-text-light)] mt-2">{post.data.description}</p>
          )}
        </a>
      ))}
      {posts.length === 0 && (
        <p class="text-[var(--color-text-light)] text-sm py-12 text-center">还没有文章，敬请期待 ✦</p>
      )}
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.tag-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');

      document.querySelectorAll('.tag-filter').forEach(b => {
        b.classList.remove('active', 'bg-[var(--color-accent)]', 'text-white');
        b.classList.add('border-[var(--color-border)]');
      });
      btn.classList.add('active', 'bg-[var(--color-accent)]', 'text-white');
      btn.classList.remove('border-[var(--color-border)]');

      document.querySelectorAll('.post-item').forEach(item => {
        const tags = item.getAttribute('data-tags')?.split(',') || [];
        if (tag === 'all' || tags.includes(tag)) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
