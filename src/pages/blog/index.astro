---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))];
const CATEGORIES = ['学习心得', '项目推荐', '踩坑记录', '东拉西扯'];

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<Layout title="博客">
  <div class="blog-shell">
    <!-- 主内容：居中 max-w-4xl -->
    <section class="blog-main">
      <h1 class="page-title">博客</h1>
      <p class="page-desc">技术笔记、学习心得、踩坑记录</p>

      {allTags.length > 0 && (
        <div class="tag-row">
          <button class="tag-btn active" data-tag="all">全部</button>
          {allTags.map(tag => (
            <button class="tag-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>
      )}

      <div class="post-list" id="post-list">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="post-card" data-tags={post.data.tags.join(',')} data-category={post.data.category || ''}>
            <div class="post-head">
              <span class="post-date">{formatDate(post.data.date)}</span>
              {post.data.category && (
                <span class="post-cat">{post.data.category}</span>
              )}
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <div class="post-tags">
              {post.data.tags.map(tag => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
            {post.data.description && (
              <p class="post-desc">{post.data.description}</p>
            )}
          </a>
        ))}
        {posts.length === 0 && (
          <p class="empty-hint">还没有文章，敬请期待</p>
        )}
      </div>
    </section>

    <!-- 右侧：分类筛选，利用右侧空白 -->
    <aside class="blog-sidebar">
      <div class="cat-card">
        <h3 class="cat-title">分类筛选</h3>
        <div class="cat-list">
          <label class="cat-item">
            <input type="checkbox" class="cat-check" data-category="all" checked />
            <span class="cat-label">全部</span>
          </label>
          {CATEGORIES.map(cat => (
            <label class="cat-item">
              <input type="checkbox" class="cat-check" data-category={cat} />
              <span class="cat-label">{cat}</span>
            </label>
          ))}
        </div>
      </div>
    </aside>
  </div>
</Layout>

<script>
  const catChecks = document.querySelectorAll<HTMLInputElement>('.cat-check');
  const tagBtns = document.querySelectorAll<HTMLElement>('.tag-btn');

  function getSelectedCategories(): string[] {
    const selected: string[] = [];
    catChecks.forEach(ch => {
      if (ch.checked) selected.push(ch.getAttribute('data-category') || '');
    });
    return selected;
  }

  function applyFilter() {
    const cats = getSelectedCategories();
    const hasAll = cats.includes('all');
    document.querySelectorAll<HTMLElement>('.post-card').forEach(item => {
      const itemCat = item.getAttribute('data-category') || '';
      item.style.display = (hasAll || cats.includes(itemCat)) ? '' : 'none';
    });
  }

  // 分类复选框
  catChecks.forEach(ch => {
    ch.addEventListener('change', () => {
      const cat = ch.getAttribute('data-category');
      if (cat === 'all') {
        // 勾选"全部"→ 取消其他；取消"全部"→ 不影响
        if (ch.checked) {
          catChecks.forEach(c => { if (c !== ch) c.checked = false; });
        }
      } else {
        // 勾选其他→ 取消"全部"
        if (ch.checked) {
          const allCh = document.querySelector<HTMLInputElement>('.cat-check[data-category="all"]');
          if (allCh) allCh.checked = false;
        }
        // 全部取消→ 自动勾选"全部"
        const anyChecked = [...catChecks].some(c => c.getAttribute('data-category') !== 'all' && c.checked);
        if (!anyChecked) {
          const allCh = document.querySelector<HTMLInputElement>('.cat-check[data-category="all"]');
          if (allCh) allCh.checked = true;
        }
      }
      applyFilter();

      // 重置 tag 筛选
      tagBtns.forEach(b => b.classList.remove('active'));
      const allTagBtn = document.querySelector<HTMLElement>('.tag-btn[data-tag="all"]');
      if (allTagBtn) allTagBtn.classList.add('active');
    });
  });

  // 标签筛选
  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');
      tagBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      document.querySelectorAll<HTMLElement>('.post-card').forEach(item => {
        const tags = item.getAttribute('data-tags')?.split(',') || [];
        item.style.display = (tag === 'all' || tags.includes(tag || '')) ? '' : 'none';
      });

      // 重置分类筛选
      catChecks.forEach(c => { c.checked = c.getAttribute('data-category') === 'all'; });
    });
  });
</script>

<style>
  .blog-shell {
    display: flex;
    justify-content: center;
    padding: 2rem 1rem;
    gap: 2rem;
    position: relative;
    width: 100%;
  }
  @media (min-width: 640px) {
    .blog-shell { padding: 3rem 1.5rem; }
  }

  .blog-main {
    width: 100%;
  }

  /* 侧边栏：桌面端贴右侧，移动端隐藏 */
  .blog-sidebar {
    display: none;
  }
  @media (min-width: 1100px) {
    .blog-sidebar {
      display: block;
      width: 180px;
      flex-shrink: 0;
      position: sticky;
      top: 5rem;
      align-self: flex-start;
    }
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--color-text);
  }
  @media (min-width: 640px) {
    .page-title { font-size: 1.75rem; }
  }

  .page-desc {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  /* 分类卡片 */
  .cat-card {
    background: var(--color-bg-card);
    border-radius: 12px;
    padding: 1rem;
    box-shadow: 0 2px 12px rgba(159, 64, 45, 0.06);
  }

  .cat-title {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .cat-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--color-text);
  }

  .cat-check {
    width: 16px;
    height: 16px;
    accent-color: var(--color-accent);
    cursor: pointer;
    flex-shrink: 0;
  }

  .cat-label {
    user-select: none;
  }

  /* 标签筛选 */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag-btn {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--color-text-light);
  }
  .tag-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .tag-btn:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* 文章列表 */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-card {
    display: block;
    background: var(--color-bg-card);
    border-radius: 12px;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 12px rgba(159, 64, 45, 0.06);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(159, 64, 45, 0.12);
  }
  @media (min-width: 640px) {
    .post-card { padding: 1.25rem 1.5rem; }
  }

  .post-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  .post-cat {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 999px;
    font-weight: 500;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  @media (min-width: 640px) {
    .post-title { font-size: 1.05rem; }
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.5rem;
  }

  .post-tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    border-radius: 999px;
    font-weight: 500;
  }

  .post-desc {
    font-size: 0.8rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  .empty-hint {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.85rem;
    padding: 3rem 0;
  }
</style>
