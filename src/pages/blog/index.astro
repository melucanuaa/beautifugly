---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))];
const CATEGORIES = ['学习心得', '项目推荐', '踩坑记录', '东拉西扯'];

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<Layout title="博客">
  {/* Page header */}
  <div class="page-header">
    <h1>博客</h1>
    <p>技术笔记、学习心得、踩坑记录</p>
  </div>

  {/* Tag filter row */}
  {allTags.length > 0 && (
    <div class="tag-row">
      <button class="tag-btn active" data-tag="all">全部</button>
      {allTags.map(tag => (
        <button class="tag-btn" data-tag={tag}>{tag}</button>
      ))}
    </div>
  )}

  {/* Post list */}
  <div class="post-list" id="post-list">
    {posts.map(post => (
      <a href={`/blog/${post.id}`} class="post-card" data-tags={post.data.tags.join(',')} data-category={post.data.category || ''}>
        <div class="post-line1">
          {post.data.category && (
            <span class="post-cat">{post.data.category}</span>
          )}
          <h2 class="post-title">{post.data.title}</h2>
        </div>
        <div class="post-line2">
          <div class="post-tags">
            {post.data.tags.map(tag => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
          <span class="post-date">{formatDate(post.data.date)}</span>
        </div>
      </a>
    ))}
    {posts.length === 0 && (
      <p class="empty-hint">还没有文章，敬请期待</p>
    )}
  </div>

  {/* Right sidebar: category filter */}
  <Fragment slot="right-sidebar">
    <div class="cat-card">
      <h3 class="cat-title">分类筛选</h3>
      <div class="cat-list">
        <label class="cat-item">
          <input type="checkbox" class="cat-check" data-category="all" checked />
          <span class="cat-label">全部</span>
        </label>
        {CATEGORIES.map(cat => (
          <label class="cat-item">
            <input type="checkbox" class="cat-check" data-category={cat} />
            <span class="cat-label">{cat}</span>
          </label>
        ))}
      </div>
    </div>
  </Fragment>
</Layout>

<script>
  const catChecks = document.querySelectorAll<HTMLInputElement>('.cat-check');
  const tagBtns = document.querySelectorAll<HTMLElement>('.tag-btn');

  function getSelectedCategories(): string[] {
    const selected: string[] = [];
    catChecks.forEach(ch => {
      if (ch.checked) selected.push(ch.getAttribute('data-category') || '');
    });
    return selected;
  }

  function applyFilter() {
    const cats = getSelectedCategories();
    const hasAll = cats.includes('all');
    document.querySelectorAll<HTMLElement>('.post-card').forEach(item => {
      const itemCat = item.getAttribute('data-category') || '';
      item.style.display = (hasAll || cats.includes(itemCat)) ? '' : 'none';
    });
  }

  // 分类复选框
  catChecks.forEach(ch => {
    ch.addEventListener('change', () => {
      const cat = ch.getAttribute('data-category');
      if (cat === 'all') {
        // 勾选"全部"→ 取消其他；取消"全部"→ 不影响
        if (ch.checked) {
          catChecks.forEach(c => { if (c !== ch) c.checked = false; });
        }
      } else {
        // 勾选其他→ 取消"全部"
        if (ch.checked) {
          const allCh = document.querySelector<HTMLInputElement>('.cat-check[data-category="all"]');
          if (allCh) allCh.checked = false;
        }
        // 全部取消→ 自动勾选"全部"
        const anyChecked = [...catChecks].some(c => c.getAttribute('data-category') !== 'all' && c.checked);
        if (!anyChecked) {
          const allCh = document.querySelector<HTMLInputElement>('.cat-check[data-category="all"]');
          if (allCh) allCh.checked = true;
        }
      }
      applyFilter();

      // 重置 tag 筛选
      tagBtns.forEach(b => b.classList.remove('active'));
      const allTagBtn = document.querySelector<HTMLElement>('.tag-btn[data-tag="all"]');
      if (allTagBtn) allTagBtn.classList.add('active');
    });
  });

  // 标签筛选
  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');
      tagBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      document.querySelectorAll<HTMLElement>('.post-card').forEach(item => {
        const tags = item.getAttribute('data-tags')?.split(',') || [];
        item.style.display = (tag === 'all' || tags.includes(tag || '')) ? '' : 'none';
      });

      // 重置分类筛选
      catChecks.forEach(c => { c.checked = c.getAttribute('data-category') === 'all'; });
    });
  });

  // 从 URL 参数初始化标签筛选
  const urlParams = new URLSearchParams(window.location.search);
  const tagParam = urlParams.get('tag');
  if (tagParam) {
    const targetBtn = document.querySelector<HTMLElement>(`.tag-btn[data-tag="${tagParam}"]`);
    if (targetBtn) {
      targetBtn.click();
    }
  }
</script>

<style>
  /* Tag filter row */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag-btn {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--color-text-light);
  }
  .tag-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
  .tag-btn:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
  }

  /* Post list */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  /* Timeline line */
  .post-list::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-accent), var(--color-border));
    border-radius: 1px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-bg-card);
    border-radius: 12px;
    padding: 1rem 1.25rem 1rem 1.5rem;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 12px rgba(159, 64, 45, 0.06);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    margin-bottom: 0.75rem;
    border: 1px solid transparent;
  }

  /* Timeline dot */
  .post-card::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 1.5rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 20%, transparent);
    z-index: 1;
    transition: all 0.3s;
  }

  .post-card:hover::before {
    transform: scale(1.3);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }
  @media (min-width: 768px) {
    .post-card {
      padding: 1rem 1.5rem 1rem 2rem;
    }
    .post-card::before {
      left: -5px;
    }
  }

  /* Hide timeline on mobile for cleaner look */
  @media (max-width: 767px) {
    .post-list::before {
      display: none;
    }
    .post-card {
      padding-left: 1rem;
    }
    .post-card::before {
      display: none;
    }
  }
  .post-card:hover {
    transform: translateX(4px);
    box-shadow: 0 4px 20px rgba(159, 64, 45, 0.12);
    border-color: color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  /* Line 1: category + title */
  .post-line1 {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    min-width: 0;
  }

  .post-cat {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 999px;
    font-weight: 600;
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  @media (min-width: 640px) {
    .post-title { font-size: 1.05rem; }
  }

  /* Line 2: tags + date (date right-aligned) */
  .post-line2 {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    min-width: 0;
    overflow: hidden;
  }

  .post-tag {
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    border-radius: 999px;
    font-weight: 500;
    white-space: nowrap;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-text-light);
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: auto;
  }

  .empty-hint {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.85rem;
    padding: 3rem 0;
  }

  /* Category card (right sidebar) */
  .cat-card {
    background: var(--color-bg-card);
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: 0 2px 12px rgba(159, 64, 45, 0.06);
    border: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
  }

  .cat-title {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .cat-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--color-text);
  }

  .cat-check {
    width: 16px;
    height: 16px;
    accent-color: var(--color-accent);
    cursor: pointer;
    flex-shrink: 0;
  }

  .cat-label {
    user-select: none;
  }
</style>
