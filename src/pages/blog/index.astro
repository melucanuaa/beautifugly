---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))];
const allCategories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
const CATEGORIES = ['学习心得', '项目推荐', '踩坑记录', '东拉西扯'];

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<Layout title="博客">
  <section class="blog-page">
    <h1 class="page-title">博客</h1>
    <p class="page-desc">技术笔记、学习心得、踩坑记录</p>

    <div class="blog-layout">
      <!-- 左侧：文章列表 -->
      <div class="blog-main">
        {allTags.length > 0 && (
          <div class="tag-row">
            <button class="tag-btn active" data-tag="all">全部</button>
            {allTags.map(tag => (
              <button class="tag-btn" data-tag={tag}>{tag}</button>
            ))}
          </div>
        )}

        <div class="post-list" id="post-list">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="post-card" data-tags={post.data.tags.join(',')} data-category={post.data.category || ''}>
              <div class="post-head">
                <span class="post-date">{formatDate(post.data.date)}</span>
                {post.data.category && (
                  <span class="post-cat">{post.data.category}</span>
                )}
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <div class="post-tags">
                {post.data.tags.map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
              {post.data.description && (
                <p class="post-desc">{post.data.description}</p>
              )}
            </a>
          ))}
          {posts.length === 0 && (
            <p class="empty-hint">还没有文章，敬请期待</p>
          )}
        </div>
      </div>

      <!-- 右侧：分类筛选 -->
      <aside class="blog-sidebar">
        <div class="cat-card">
          <h3 class="cat-title">分类</h3>
          <div class="cat-list">
            <button class="cat-btn active" data-category="all">全部</button>
            {CATEGORIES.map(cat => (
              <button class="cat-btn" data-category={cat}>{cat}</button>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  // 分类筛选
  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');

      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      document.querySelectorAll('.post-item, .post-card').forEach(item => {
        const itemCat = item.getAttribute('data-category') || '';
        if (cat === 'all' || itemCat === cat) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });

      // 重置 tag 筛选
      document.querySelectorAll('.tag-btn').forEach(b => b.classList.remove('active'));
      const allTagBtn = document.querySelector('.tag-btn[data-tag="all"]');
      if (allTagBtn) allTagBtn.classList.add('active');
    });
  });

  // 标签筛选
  document.querySelectorAll('.tag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');

      document.querySelectorAll('.tag-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      document.querySelectorAll('.post-item, .post-card').forEach(item => {
        const tags = item.getAttribute('data-tags')?.split(',') || [];
        if (tag === 'all' || tags.includes(tag)) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });

      // 重置分类筛选
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      const allCatBtn = document.querySelector('.cat-btn[data-category="all"]');
      if (allCatBtn) allCatBtn.classList.add('active');
    });
  });
</script>

<style>
  .blog-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  @media (min-width: 640px) {
    .blog-page { padding: 3rem 1.5rem; }
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--color-text);
  }
  @media (min-width: 640px) {
    .page-title { font-size: 1.75rem; }
  }

  .page-desc {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  /* 两栏布局 */
  .blog-layout {
    display: flex;
    flex-direction: column-reverse;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .blog-layout {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .blog-main { flex: 1; min-width: 0; }

  .blog-sidebar {
    width: 100%;
  }
  @media (min-width: 768px) {
    .blog-sidebar {
      width: 200px;
      flex-shrink: 0;
      position: sticky;
      top: 5rem;
    }
  }

  /* 分类卡片 */
  .cat-card {
    background: var(--color-bg-card);
    border-radius: 12px;
    padding: 1rem;
    box-shadow: 0 2px 12px rgba(159, 64, 45, 0.06);
  }

  .cat-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .cat-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .cat-list {
      flex-direction: column;
    }
  }

  .cat-btn {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--color-text-light);
    white-space: nowrap;
  }
  .cat-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .cat-btn:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* 标签筛选 */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag-btn {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--color-text-light);
  }
  .tag-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .tag-btn:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* 文章列表 */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-card {
    display: block;
    background: var(--color-bg-card);
    border-radius: 12px;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 12px rgba(159, 64, 45, 0.06);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(159, 64, 45, 0.12);
  }
  @media (min-width: 640px) {
    .post-card { padding: 1.25rem 1.5rem; }
  }

  .post-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  .post-cat {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 999px;
    font-weight: 500;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  @media (min-width: 640px) {
    .post-title { font-size: 1.05rem; }
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.5rem;
  }

  .post-tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-accent);
    color: var(--color-accent);
    border-radius: 999px;
    opacity: 0.15;
    font-weight: 500;
  }
  /* 修正：用 bg 的 10% 透明度 */
  .post-tag {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    opacity: 1;
  }

  .post-desc {
    font-size: 0.8rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  .empty-hint {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.85rem;
    padding: 3rem 0;
  }
</style>
