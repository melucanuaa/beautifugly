---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <a href="/blog" class="text-sm text-[var(--color-accent)] hover:underline mb-8 inline-block">← 返回博客</a>

    <header class="mb-8">
      <h1 class="font-[var(--font-pixel)] text-xl md:text-2xl mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-sm text-[var(--color-text-light)]">
        <span>{formatDate(post.data.date)}</span>
        <div class="flex gap-2">
          {post.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 bg-[var(--color-accent)]/10 rounded">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    {post.data.image && (
      <img src={post.data.image} alt={post.data.title} class="w-full rounded-lg mb-8" loading="lazy" />
    )}

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-family: var(--font-pixel);
    font-size: 0.9rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(h3) {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .prose :global(code) {
    background: var(--color-border);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--color-text);
    color: var(--color-bg);
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  .prose :global(img) {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }
</style>
