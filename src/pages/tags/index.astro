---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blog = (await getCollection('blog')).filter(p => !p.data.draft);
const works = (await getCollection('works')).filter(w => !w.data.draft);
const projects = (await getCollection('projects')).filter(p => !p.data.draft);

const allItems = [
  ...blog.map(p => ({ ...p.data, type: 'blog' as const, url: `/blog/${p.id}/` })),
  ...works.map(w => ({ ...w.data, type: 'works' as const, url: `/works/${w.id}/` })),
  ...projects.map(p => ({ ...p.data, type: 'projects' as const, url: `/projects/${p.id}/` })),
];

const tagMap = new Map<string, typeof allItems>();
allItems.forEach(item => {
  item.tags.forEach(tag => {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(item);
  });
});

const sortedTags = [...tagMap.entries()].sort((a, b) => b[1].length - a[1].length);

const typeLabels = {
  blog: '博客',
  works: '作品',
  projects: '项目',
};
---

<Layout title="分类标签">
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="font-[var(--font-pixel)] text-xl mb-2">✦ 分类标签</h1>
    <p class="text-[var(--color-text-light)] mb-8">按标签浏览所有内容</p>

    <div class="grid gap-6">
      {sortedTags.map(([tag, items]) => (
        <div class="card p-6">
          <div class="flex items-center gap-3 mb-4">
            <h2 class="font-[var(--font-pixel)] text-sm">{tag}</h2>
            <span class="text-xs px-2 py-0.5 bg-[var(--color-accent)]/10 rounded">{items.length} 篇</span>
          </div>
          <ul class="space-y-2">
            {items.map(item => (
              <li class="flex items-center gap-3">
                <span class="text-[10px] px-1.5 py-0.5 bg-[var(--color-accent-purple)]/10 rounded shrink-0">
                  {typeLabels[item.type]}
                </span>
                <a href={item.url} class="text-sm hover:text-[var(--color-accent)] transition-colors truncate">
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
      {sortedTags.length === 0 && (
        <p class="text-[var(--color-text-light)] text-sm py-12 text-center">暂无标签内容</p>
      )}
    </div>
  </section>
</Layout>
