---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const works = (await getCollection('works')).filter(w => !w.data.draft);
  return works.map(work => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout
  title={work.data.title}
  description={work.data.description || work.data.title}
  image={work.data.image}
  type="article"
  publishDate={work.data.date}
  tags={work.data.tags}
>
  <article class="max-w-4xl px-6 py-12">
    <a href="/works" class="text-sm text-[var(--color-accent)] hover:underline mb-8 inline-block">← 返回作品集</a>

    <header class="mb-8">
      <h1 class="font-[var(--font-heading)] text-xl md:text-2xl mb-4">{work.data.title}</h1>
      <div class="flex items-center gap-3 flex-wrap text-sm text-[var(--color-text-light)]">
        <span>{formatDate(work.data.date)}</span>
        <div class="flex gap-1.5 flex-wrap">
          {work.data.tags.map(tag => (
            <span class="text-xs px-2 py-0.5 bg-[var(--color-accent)]/10 rounded">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    {work.data.image && (
      <img src={work.data.image} alt={work.data.title} class="w-full rounded-lg mb-8" loading="lazy" />
    )}

    {work.data.description && (
      <p class="text-lg text-[var(--color-text-light)] mb-8">{work.data.description}</p>
    )}

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .prose :global(img) {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h4) {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(h5) {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(h6) {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(code) {
    background: var(--color-border);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--color-text);
    color: var(--color-bg);
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
  }

  .prose :global(th) {
    background: var(--color-bg-card);
    font-weight: 600;
    text-align: left;
    padding: 10px 14px;
    border-bottom: 2px solid var(--color-border);
  }

  .prose :global(td) {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }
</style>
