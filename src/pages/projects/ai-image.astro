---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI 图片生成" description="使用 GPT IMAGE 2 在线生成图片，支持文生图和图生图">
  <section class="max-w-4xl mx-auto px-6 py-12">
    <a href="/projects" class="text-sm text-[var(--color-accent)] hover:underline mb-8 inline-block">← 返回项目</a>

    <h1 class="font-[var(--font-heading)] text-xl md:text-2xl mb-2">✦ AI 图片生成</h1>
    <p class="text-[var(--color-text-light)] mb-8">使用 GPT IMAGE 2 在线文生图 / 图生图</p>

    <!-- API Key 输入 -->
    <div class="card p-6 mb-6">
      <label class="block text-sm font-medium mb-2">API Key</label>
      <div class="flex gap-3">
        <input
          id="api-key"
          type="password"
          placeholder="输入你的 API Key"
          class="flex-1 bg-transparent border border-[var(--color-border)] rounded-lg px-4 py-2.5 text-sm outline-none focus:border-[var(--color-accent)] transition-colors"
        />
        <button id="btn-confirm-key" class="btn-primary text-xs">确认</button>
      </div>
      <p id="key-status" class="text-xs mt-2 text-[var(--color-text-light)]"></p>
    </div>

    <!-- 模式切换 -->
    <div class="flex gap-2 mb-6">
      <button id="tab-txt" class="btn-primary text-xs">文生图</button>
      <button id="tab-img" class="btn-secondary text-xs">图生图</button>
    </div>

    <!-- 参数面板 -->
    <div class="card p-6 mb-6">
      <!-- 提示词 -->
      <label class="block text-sm font-medium mb-2">提示词</label>
      <textarea
        id="prompt"
        rows="4"
        placeholder="描述你想要的图片，越详细效果越好..."
        class="w-full bg-transparent border border-[var(--color-border)] rounded-lg px-4 py-3 text-sm outline-none focus:border-[var(--color-accent)] transition-colors resize-none mb-4"
      ></textarea>

      <!-- 尺寸选择 -->
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <label class="text-sm font-medium">尺寸</label>
        <div id="size-options" class="flex gap-2">
          <button data-size="1:1" class="size-btn btn-primary text-xs">1:1</button>
          <button data-size="16:9" class="size-btn btn-secondary text-xs">16:9</button>
          <button data-size="9:16" class="size-btn btn-secondary text-xs">9:16</button>
          <button data-size="4:3" class="size-btn btn-secondary text-xs">4:3</button>
          <button data-size="3:4" class="size-btn btn-secondary text-xs">3:4</button>
        </div>
      </div>

      <!-- 图生图：图片上传 -->
      <div id="upload-area" class="hidden mb-4">
        <label class="block text-sm font-medium mb-2">上传图片</label>
        <div
          id="drop-zone"
          class="border border-dashed border-[var(--color-border)] rounded-lg p-8 text-center cursor-pointer hover:border-[var(--color-accent)] transition-colors"
        >
          <input id="file-input" type="file" accept="image/*" class="hidden" />
          <p id="upload-text" class="text-sm text-[var(--color-text-light)]">点击或拖拽图片到此处</p>
          <img id="preview-img" class="hidden max-h-48 mx-auto rounded-lg mt-3" />
        </div>
      </div>

      <!-- 生成按钮 -->
      <button id="btn-generate" class="btn-primary text-xs w-full" disabled>
        生成图片
      </button>
    </div>

    <!-- 结果区 -->
    <div id="result-area" class="hidden">
      <div class="card p-6">
        <h2 class="font-[var(--font-heading)] text-sm mb-4">✦ 生成结果</h2>

        <!-- 加载状态 -->
        <div id="loading" class="hidden text-center py-12">
          <div class="inline-block w-8 h-8 border-3 border-[var(--color-accent)] border-t-transparent rounded-full animate-spin mb-3"></div>
          <p class="text-sm text-[var(--color-text-light)]">正在生成，请稍候...</p>
        </div>

        <!-- 错误提示 -->
        <div id="error-msg" class="hidden text-center py-8">
          <p class="text-sm text-red-500"></p>
        </div>

        <!-- 图片结果 -->
        <div id="result-img-area" class="hidden">
          <img id="result-img" class="w-full rounded-lg mb-4" />
          <div class="flex justify-between items-center">
            <p id="revised-prompt" class="text-xs text-[var(--color-text-light)] flex-1 mr-4"></p>
            <a id="btn-download" class="btn-primary text-xs" download="ai-generated.png">
              下载图片
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const API_BASE = 'https://image.perfectisshit.com';
  const API_PATH_GENERATE = '/v1/images/generations';
  const API_PATH_EDIT = '/v1/images/edits';
  const TIMEOUT_MS = 60000;

  // State
  let apiKey = '';
  let currentMode: 'txt2img' | 'img2img' = 'txt2img';
  let selectedSize = '1:1';
  let uploadedFile: File | null = null;

  // DOM elements
  const keyInput = document.getElementById('api-key') as HTMLInputElement;
  const btnConfirmKey = document.getElementById('btn-confirm-key')!;
  const keyStatus = document.getElementById('key-status')!;
  const tabTxt = document.getElementById('tab-txt')!;
  const tabImg = document.getElementById('tab-img')!;
  const promptInput = document.getElementById('prompt') as HTMLTextAreaElement;
  const sizeOptions = document.getElementById('size-options')!;
  const uploadArea = document.getElementById('upload-area')!;
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadText = document.getElementById('upload-text')!;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const btnGenerate = document.getElementById('btn-generate') as HTMLButtonElement;
  const resultArea = document.getElementById('result-area')!;
  const loading = document.getElementById('loading')!;
  const errorMsg = document.getElementById('error-msg')!;
  const resultImgArea = document.getElementById('result-img-area')!;
  const resultImg = document.getElementById('result-img') as HTMLImageElement;
  const revisedPrompt = document.getElementById('revised-prompt')!;
  const btnDownload = document.getElementById('btn-download') as HTMLAnchorElement;

  // API Key
  btnConfirmKey.addEventListener('click', () => {
    const val = keyInput.value.trim();
    if (!val) {
      keyStatus.textContent = '请输入 API Key';
      keyStatus.className = 'text-xs mt-2 text-red-500';
      return;
    }
    apiKey = val;
    keyStatus.textContent = '✓ 已连接';
    keyStatus.className = 'text-xs mt-2 text-[var(--color-accent)]';
    updateGenerateBtn();
  });

  // Mode tabs
  function setMode(mode: 'txt2img' | 'img2img') {
    currentMode = mode;
    if (mode === 'txt2img') {
      tabTxt.className = 'btn-primary text-xs';
      tabImg.className = 'btn-secondary text-xs';
      uploadArea.classList.add('hidden');
    } else {
      tabTxt.className = 'btn-secondary text-xs';
      tabImg.className = 'btn-primary text-xs';
      uploadArea.classList.remove('hidden');
    }
    updateGenerateBtn();
  }

  tabTxt.addEventListener('click', () => setMode('txt2img'));
  tabImg.addEventListener('click', () => setMode('img2img'));

  // Size selection
  sizeOptions.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-size]') as HTMLElement;
    if (!btn) return;
    selectedSize = btn.dataset.size!;
    sizeOptions.querySelectorAll('.size-btn').forEach(b => {
      b.className = 'size-btn btn-secondary text-xs';
    });
    btn.className = 'size-btn btn-primary text-xs';
  });

  // File upload
  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-[var(--color-accent)]');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-[var(--color-accent)]');
  });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-[var(--color-accent)]');
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith('image/')) handleFile(file);
  });
  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) handleFile(file);
  });

  function handleFile(file: File) {
    uploadedFile = file;
    uploadText.textContent = file.name;
    const reader = new FileReader();
    reader.onload = () => {
      previewImg.src = reader.result as string;
      previewImg.classList.remove('hidden');
    };
    reader.readAsDataURL(file);
    updateGenerateBtn();
  }

  // Generate button state
  function updateGenerateBtn() {
    const hasKey = !!apiKey;
    const hasPrompt = !!promptInput.value.trim();
    const hasImage = currentMode === 'txt2img' || uploadedFile;
    btnGenerate.disabled = !(hasKey && hasPrompt && hasImage);
  }

  promptInput.addEventListener('input', updateGenerateBtn);

  // Generate
  btnGenerate.addEventListener('click', async () => {
    if (btnGenerate.disabled) return;

    // Show result area and loading
    resultArea.classList.remove('hidden');
    loading.classList.remove('hidden');
    errorMsg.classList.add('hidden');
    resultImgArea.classList.add('hidden');
    btnGenerate.disabled = true;
    btnGenerate.textContent = '生成中...';

    try {
      let response: Response;

      if (currentMode === 'txt2img') {
        response = await fetch(API_BASE + API_PATH_GENERATE, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${apiKey}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            model: 'gpt-image-2',
            prompt: promptInput.value.trim(),
            n: 1,
            size: selectedSize,
            response_format: 'url',
            stream: false,
          }),
          signal: AbortSignal.timeout(TIMEOUT_MS),
        });
      } else {
        const formData = new FormData();
        formData.append('image', uploadedFile!);
        formData.append('prompt', promptInput.value.trim());
        formData.append('model', 'gpt-image-2');
        formData.append('n', '1');
        formData.append('size', selectedSize);
        formData.append('response_format', 'url');

        response = await fetch(API_BASE + API_PATH_EDIT, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${apiKey}`,
          },
          body: formData,
          signal: AbortSignal.timeout(TIMEOUT_MS),
        });
      }

      if (!response.ok) {
        const errBody = await response.text();
        let msg = '生成失败';
        if (response.status === 401) msg = 'API Key 无效，请检查后重试';
        else if (response.status === 429) msg = '请求过于频繁，请稍后重试';
        else if (response.status === 400) msg = '请求参数错误：' + errBody;
        else if (response.status >= 500) msg = '服务器内部错误，请稍后重试';
        throw new Error(msg);
      }

      const data = await response.json();
      const imgUrl = data.data?.[0]?.url;
      if (!imgUrl) throw new Error('未获取到图片地址');

      // Ensure HTTPS
      const secureUrl = imgUrl.replace(/^http:\/\//, 'https://');

      // Show result
      loading.classList.add('hidden');
      resultImgArea.classList.remove('hidden');
      resultImg.src = secureUrl;
      btnDownload.href = secureUrl;

      const revised = data.data?.[0]?.revised_prompt;
      revisedPrompt.textContent = revised ? `优化后的提示词：${revised}` : '';

    } catch (err: any) {
      loading.classList.add('hidden');
      errorMsg.classList.remove('hidden');
      const p = errorMsg.querySelector('p')!;
      if (err.name === 'TimeoutError') {
        p.textContent = '生成超时，请重试';
      } else if (err.message?.includes('Failed to fetch') || err.message?.includes('NetworkError')) {
        p.textContent = '网络连接失败，请检查网络或 API 地址';
      } else {
        p.textContent = err.message || '生成失败';
      }
    } finally {
      btnGenerate.disabled = false;
      btnGenerate.textContent = '生成图片';
      updateGenerateBtn();
    }
  });
</script>

<style>
  .animate-spin {
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .border-3 {
    border-width: 3px;
  }
</style>
