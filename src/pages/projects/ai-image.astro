---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI 生图" description="使用 GPT IMAGE 2 在线生成图片，支持文生图和图生图">
  <section class="py-4">
    <a href="/projects" class="text-sm text-[var(--color-accent)] hover:underline mb-6 inline-block">← 返回项目</a>

    <h1 class="font-[var(--font-heading)] text-xl md:text-2xl mb-2">AI 生图</h1>
    <p class="text-sm text-[var(--color-text-light)] mb-6">使用 GPT IMAGE 2 在线文生图 / 图生图</p>

    <div class="ai-layout">
      {/* Left: Config Panel */}
      <div class="ai-config">
        {/* API Key */}
        <div class="ai-card">
          <label class="field-label">API Key</label>
          <div class="key-row">
            <input id="api-key" type="password" placeholder="输入你的 API Key" class="key-input" />
            <button id="btn-confirm-key" class="btn-accent">确认</button>
          </div>
          <p id="key-status" class="key-status"></p>
        </div>

        {/* Mode Toggle */}
        <div class="mode-toggle">
          <button id="tab-txt" class="mode-btn active">文生图</button>
          <button id="tab-img" class="mode-btn">图生图</button>
        </div>

        {/* Prompt */}
        <div class="ai-card">
          <label class="field-label">提示词</label>
          <textarea id="prompt" rows="5" placeholder="描述你想要的图片，越详细效果越好..." class="prompt-input"></textarea>

          <label class="field-label">尺寸</label>
          <div id="size-options" class="size-row">
            <button data-size="1:1" class="size-btn active">1:1</button>
            <button data-size="16:9" class="size-btn">16:9</button>
            <button data-size="9:16" class="size-btn">9:16</button>
            <button data-size="4:3" class="size-btn">4:3</button>
            <button data-size="3:4" class="size-btn">3:4</button>
          </div>

          {/* Upload (img2img) */}
          <div id="upload-area" class="hidden">
            <label class="field-label">上传图片</label>
            <div id="drop-zone" class="drop-zone">
              <input id="file-input" type="file" accept="image/*" class="hidden" />
              <p id="upload-text" class="drop-text">点击或拖拽图片到此处</p>
              <img id="preview-img" class="preview-img hidden" />
            </div>
          </div>

          <button id="btn-generate" class="btn-generate" disabled>生成图片</button>
        </div>
      </div>

      {/* Right: Result Panel */}
      <div class="ai-result">
        <div id="result-area" class="result-area">
          {/* Empty state */}
          <div id="empty-state" class="empty-state">
            <div class="empty-icon">✦</div>
            <p class="empty-text">输入提示词，点击生成</p>
            <p class="empty-hint">生成的图片将显示在这里</p>
          </div>

          {/* Loading */}
          <div id="loading" class="loading hidden">
            <div class="spinner"></div>
            <p class="loading-text">正在生成，请稍候...</p>
          </div>

          {/* Error */}
          <div id="error-msg" class="error-msg hidden">
            <p></p>
          </div>

          {/* Result Image */}
          <div id="result-img-area" class="result-img-area hidden">
            <img id="result-img" class="result-img" />
            <p id="revised-prompt" class="revised-prompt"></p>
            <a id="btn-download" class="btn-accent" download="ai-generated.png">下载图片</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const API_BASE = 'https://image.perfectisshit.com';
  const API_PATH_GENERATE = '/v1/images/generations';
  const API_PATH_EDIT = '/v1/images/edits';
  const TIMEOUT_MS = 60000;

  let apiKey = '';
  let currentMode: 'txt2img' | 'img2img' = 'txt2img';
  let selectedSize = '1:1';
  let uploadedFile: File | null = null;

  const keyInput = document.getElementById('api-key') as HTMLInputElement;
  const btnConfirmKey = document.getElementById('btn-confirm-key')!;
  const keyStatus = document.getElementById('key-status')!;
  const tabTxt = document.getElementById('tab-txt')!;
  const tabImg = document.getElementById('tab-img')!;
  const promptInput = document.getElementById('prompt') as HTMLTextAreaElement;
  const sizeOptions = document.getElementById('size-options')!;
  const uploadArea = document.getElementById('upload-area')!;
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadText = document.getElementById('upload-text')!;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const btnGenerate = document.getElementById('btn-generate') as HTMLButtonElement;
  const emptyState = document.getElementById('empty-state')!;
  const loading = document.getElementById('loading')!;
  const errorMsg = document.getElementById('error-msg')!;
  const resultImgArea = document.getElementById('result-img-area')!;
  const resultImg = document.getElementById('result-img') as HTMLImageElement;
  const revisedPrompt = document.getElementById('revised-prompt')!;
  const btnDownload = document.getElementById('btn-download') as HTMLAnchorElement;

  btnConfirmKey.addEventListener('click', () => {
    const val = keyInput.value.trim();
    if (!val) {
      keyStatus.textContent = '请输入 API Key';
      keyStatus.className = 'key-status error';
      return;
    }
    apiKey = val;
    keyStatus.textContent = '已连接';
    keyStatus.className = 'key-status success';
    updateGenerateBtn();
  });

  function setMode(mode: 'txt2img' | 'img2img') {
    currentMode = mode;
    tabTxt.className = mode === 'txt2img' ? 'mode-btn active' : 'mode-btn';
    tabImg.className = mode === 'img2img' ? 'mode-btn active' : 'mode-btn';
    uploadArea.classList.toggle('hidden', mode === 'txt2img');
    updateGenerateBtn();
  }

  tabTxt.addEventListener('click', () => setMode('txt2img'));
  tabImg.addEventListener('click', () => setMode('img2img'));

  sizeOptions.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-size]') as HTMLElement;
    if (!btn) return;
    selectedSize = btn.dataset.size!;
    sizeOptions.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  });

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('dragover');
  });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith('image/')) handleFile(file);
  });
  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) handleFile(file);
  });

  function handleFile(file: File) {
    uploadedFile = file;
    uploadText.textContent = file.name;
    const reader = new FileReader();
    reader.onload = () => {
      previewImg.src = reader.result as string;
      previewImg.classList.remove('hidden');
    };
    reader.readAsDataURL(file);
    updateGenerateBtn();
  }

  function updateGenerateBtn() {
    const hasKey = !!apiKey;
    const hasPrompt = !!promptInput.value.trim();
    const hasImage = currentMode === 'txt2img' || uploadedFile;
    btnGenerate.disabled = !(hasKey && hasPrompt && hasImage);
  }

  promptInput.addEventListener('input', updateGenerateBtn);

  btnGenerate.addEventListener('click', async () => {
    if (btnGenerate.disabled) return;

    emptyState.classList.add('hidden');
    loading.classList.remove('hidden');
    errorMsg.classList.add('hidden');
    resultImgArea.classList.add('hidden');
    btnGenerate.disabled = true;
    btnGenerate.textContent = '生成中...';

    try {
      let response: Response;

      if (currentMode === 'txt2img') {
        response = await fetch(API_BASE + API_PATH_GENERATE, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${apiKey}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            model: 'gpt-image-2',
            prompt: promptInput.value.trim(),
            n: 1,
            size: selectedSize,
            response_format: 'url',
            stream: false,
          }),
          signal: AbortSignal.timeout(TIMEOUT_MS),
        });
      } else {
        const formData = new FormData();
        formData.append('image', uploadedFile!);
        formData.append('prompt', promptInput.value.trim());
        formData.append('model', 'gpt-image-2');
        formData.append('n', '1');
        formData.append('size', selectedSize);
        formData.append('response_format', 'url');

        response = await fetch(API_BASE + API_PATH_EDIT, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${apiKey}` },
          body: formData,
          signal: AbortSignal.timeout(TIMEOUT_MS),
        });
      }

      if (!response.ok) {
        const errBody = await response.text();
        let msg = '生成失败';
        if (response.status === 401) msg = 'API Key 无效，请检查后重试';
        else if (response.status === 429) msg = '请求过于频繁，请稍后重试';
        else if (response.status === 400) msg = '请求参数错误：' + errBody;
        else if (response.status >= 500) msg = '服务器内部错误，请稍后重试';
        throw new Error(msg);
      }

      const data = await response.json();
      const imgUrl = data.data?.[0]?.url;
      if (!imgUrl) throw new Error('未获取到图片地址');

      const secureUrl = imgUrl.replace(/^http:\/\//, 'https://://');
      loading.classList.add('hidden');
      resultImgArea.classList.remove('hidden');
      resultImg.src = secureUrl;
      btnDownload.href = secureUrl;

      const revised = data.data?.[0]?.revised_prompt;
      revisedPrompt.textContent = revised ? `优化后的提示词：${revised}` : '';

    } catch (err: any) {
      loading.classList.add('hidden');
      errorMsg.classList.remove('hidden');
      const p = errorMsg.querySelector('p')!;
      if (err.name === 'TimeoutError') p.textContent = '生成超时，请重试';
      else if (err.message?.includes('Failed to fetch') || err.message?.includes('NetworkError'))
        p.textContent = '网络连接失败，请检查网络或 API 地址';
      else p.textContent = err.message || '生成失败';
    } finally {
      btnGenerate.disabled = false;
      btnGenerate.textContent = '生成图片';
      updateGenerateBtn();
    }
  });
</script>

<style>
  /* Layout: left config + right result */
  .ai-layout {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .ai-layout {
      flex-direction: row;
      align-items: flex-start;
    }
    .ai-config {
      width: 380px;
      flex-shrink: 0;
    }
    .ai-result {
      flex: 1;
      min-width: 0;
      position: sticky;
      top: 5rem;
    }
  }

  /* Cards */
  .ai-card {
    background: var(--color-bg-card);
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 12px rgba(159, 64, 45, 0.06);
  }
  @media (min-width: 640px) {
    .ai-card { padding: 1.25rem; }
  }

  .field-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  /* API Key */
  .key-row {
    display: flex;
    gap: 0.5rem;
  }

  .key-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .key-input:focus { border-color: var(--color-accent); }

  .key-status {
    font-size: 0.75rem;
    margin-top: 0.375rem;
    color: var(--color-text-light);
  }
  .key-status.error { color: #dc2626; }
  .key-status.success { color: var(--color-accent); }

  .btn-accent {
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.5rem 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }
  .btn-accent:hover { opacity: 0.9; }

  /* Mode Toggle */
  .mode-toggle {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .mode-btn {
    flex: 1;
    padding: 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: transparent;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--color-text-light);
  }
  .mode-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .mode-btn:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Prompt */
  .prompt-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.625rem 0.75rem;
    font-size: 0.85rem;
    outline: none;
    resize: vertical;
    margin-bottom: 1rem;
    transition: border-color 0.2s;
    min-height: 80px;
  }
  .prompt-input:focus { border-color: var(--color-accent); }

  /* Size */
  .size-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .size-btn {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--color-text-light);
  }
  .size-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .size-btn:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Upload */
  .drop-zone {
    border: 1.5px dashed var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s;
    margin-bottom: 1rem;
  }
  .drop-zone:hover, .drop-zone.dragover {
    border-color: var(--color-accent);
  }

  .drop-text {
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  .preview-img {
    max-height: 10rem;
    margin: 0.75rem auto 0;
    border-radius: 8px;
    display: block;
  }

  /* Generate Button */
  .btn-generate {
    width: 100%;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-generate:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn-generate:hover:not(:disabled) { opacity: 0.9; }

  /* Result Area */
  .result-area {
    background: var(--color-bg-card);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(159, 64, 45, 0.06);
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 2rem;
  }

  .empty-icon {
    font-size: 2.5rem;
    color: var(--color-border);
    margin-bottom: 1rem;
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .empty-text {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 0.25rem;
  }

  .empty-hint {
    font-size: 0.78rem;
    color: var(--color-border);
  }

  /* Loading */
  .loading {
    text-align: center;
    padding: 2rem;
    width: 100%;
  }

  .spinner {
    width: 2rem;
    height: 2rem;
    border: 3px solid var(--color-accent);
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 0.75rem;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .loading-text {
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  /* Error */
  .error-msg {
    text-align: center;
    padding: 1.5rem;
    width: 100%;
  }
  .error-msg p {
    font-size: 0.82rem;
    color: #dc2626;
  }

  /* Result Image */
  .result-img-area {
    width: 100%;
    text-align: center;
  }

  .result-img {
    width: 100%;
    border-radius: 10px;
    margin-bottom: 1rem;
    box-shadow: 0 4px 20px rgba(159, 64, 45, 0.1);
  }

  .revised-prompt {
    font-size: 0.78rem;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
    text-align: left;
    line-height: 1.5;
    padding: 0.75rem;
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
    border-radius: 8px;
  }

  .hidden { display: none !important; }
</style>
