---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="项目">
  <section class="w-full py-12">
    <h1 class="font-[var(--font-heading)] text-xl mb-2">✦ 项目</h1>
    <p class="text-[var(--color-text-light)] mb-8">有趣的项目、工具、实验</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {projects.map(project => (
        <a href={`/projects/${project.id}`} class="card p-6 group">
          <div class="flex items-start justify-between gap-3">
            <h3 class="font-medium text-lg group-hover:text-[var(--color-accent)] transition-colors min-w-0 truncate">{project.data.title}</h3>
            <div class="flex gap-2">
              {project.data.github && (
                <span class="text-[var(--color-text-light)]" aria-label="GitHub">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </span>
              )}
            </div>
          </div>
          <p class="text-sm text-[var(--color-text-light)] mt-3">{project.data.description}</p>
          <div class="flex gap-2 mt-4 flex-wrap">
            {project.data.tags.map(tag => (
              <span class="text-xs px-1.5 py-0.5 bg-[var(--color-accent-secondary)]/10 rounded">{tag}</span>
            ))}
          </div>
        </a>
      ))}
      {projects.length === 0 && (
        <p class="text-[var(--color-text-light)] text-sm py-12 text-center col-span-2">还没有项目，敬请期待 ✦</p>
      )}
    </div>
  </section>
</Layout>
