---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const allBlog = (await getCollection('blog')).filter(p => !p.data.draft);
const allWorks = (await getCollection('works')).filter(p => !p.data.draft);
const allProjects = (await getCollection('projects')).filter(p => !p.data.draft);

const latestBlog = allBlog.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const latestWorks = allWorks.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const latestProjects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

// Get popular tags
const allTags = [...new Set(allBlog.flatMap(p => p.data.tags))];
const tagCounts = allTags.map(tag => ({
  tag,
  count: allBlog.filter(p => p.data.tags.includes(tag)).length,
})).sort((a, b) => b.count - a.count).slice(0, 8);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<Layout>
  {/* Hero */}
  <section class="max-w-4xl mx-auto px-6 pt-8 md:pt-16 pb-12">
    <div class="flex items-start gap-3 mb-4">
      <span class="font-[var(--font-pixel)] text-3xl md:text-4xl">✦</span>
      <h1 class="font-[var(--font-pixel)] text-2xl md:text-3xl">beautifugly</h1>
    </div>
    <p class="text-[var(--color-text-light)] max-w-xl text-lg leading-relaxed">
      分享技术博文、AI 创作、有趣的项目。<br />
      一个记录成长与探索的小站。
    </p>
    <div class="flex flex-wrap gap-3 mt-6">
      <a href="/blog" class="pixel-btn bg-[var(--color-accent)] text-white">看看博客</a>
      <a href="/about" class="pixel-btn bg-[var(--color-bg-card)]">了解我</a>
    </div>
  </section>

  {/* Tags Quick Access */}
  {tagCounts.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 pb-12">
      <div class="flex flex-wrap gap-2">
        {tagCounts.map(({ tag, count }) => (
          <a href={`/blog?tag=${tag}`} class="text-xs px-3 py-1.5 bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-full hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors">
            {tag} <span class="text-[var(--color-text-light)]">({count})</span>
          </a>
        ))}
        <a href="/tags" class="text-xs px-3 py-1.5 text-[var(--color-accent)] hover:underline">
          全部标签 →
        </a>
      </div>
    </section>
  )}

  {/* Latest Blog */}
  <section class="max-w-4xl mx-auto px-6 pb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-[var(--font-pixel)] text-sm">✦ 最新博文</h2>
      <a href="/blog" class="text-sm text-[var(--color-accent)] hover:underline">查看全部 →</a>
    </div>
    <div class="grid gap-4">
      {latestBlog.map(post => (
        <a href={`/blog/${post.id}`} class="card p-5 flex flex-col md:flex-row md:items-center gap-3">
          <span class="text-xs text-[var(--color-text-light)] whitespace-nowrap">{formatDate(post.data.date)}</span>
          <span class="font-medium">{post.data.title}</span>
          <div class="flex gap-1.5 flex-wrap md:ml-auto">
            {post.data.tags.map(tag => (
              <span class="text-xs px-2 py-0.5 bg-[var(--color-accent)]/10 rounded">{tag}</span>
            ))}
          </div>
        </a>
      ))}
      {latestBlog.length === 0 && (
        <p class="text-[var(--color-text-light)] text-sm py-8 text-center">还没有文章，敬请期待 ✦</p>
      )}
    </div>
  </section>

  {/* Latest Works */}
  <section class="max-w-4xl mx-auto px-6 pb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-[var(--font-pixel)] text-sm">✦ 最新作品</h2>
      <a href="/works" class="text-sm text-[var(--color-accent)] hover:underline">查看全部 →</a>
    </div>
    <div class="grid md:grid-cols-3 gap-4">
      {latestWorks.map(work => (
        <a href={`/works/${work.id}`} class="card overflow-hidden">
          <div class="aspect-[4/3] bg-[var(--color-border)] flex items-center justify-center">
            {work.data.image ? (
              <img src={work.data.image} alt={work.data.title} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <span class="text-4xl">✦</span>
            )}
          </div>
          <div class="p-4">
            <h3 class="font-medium text-sm">{work.data.title}</h3>
            {work.data.description && (
              <p class="text-xs text-[var(--color-text-light)] mt-1 line-clamp-2">{work.data.description}</p>
            )}
          </div>
        </a>
      ))}
      {latestWorks.length === 0 && (
        <p class="text-[var(--color-text-light)] text-sm py-8 text-center col-span-3">还没有作品，敬请期待 ✦</p>
      )}
    </div>
  </section>

  {/* Latest Projects */}
  <section class="max-w-4xl mx-auto px-6 pb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-[var(--font-pixel)] text-sm">✦ 最新项目</h2>
      <a href="/projects" class="text-sm text-[var(--color-accent)] hover:underline">查看全部 →</a>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      {latestProjects.map(project => (
        <a href={`/projects/${project.id}`} class="card p-5">
          <h3 class="font-medium">{project.data.title}</h3>
          <p class="text-sm text-[var(--color-text-light)] mt-2">{project.data.description}</p>
          <div class="flex gap-2 mt-3">
            {project.data.tags.map(tag => (
              <span class="text-xs px-2 py-0.5 bg-[var(--color-accent-purple)]/10 rounded">{tag}</span>
            ))}
          </div>
        </a>
      ))}
      {latestProjects.length === 0 && (
        <p class="text-[var(--color-text-light)] text-sm py-8 text-center col-span-2">还没有项目，敬请期待 ✦</p>
      )}
    </div>
  </section>

  {/* Newsletter */}
  <section class="max-w-4xl mx-auto px-6 pb-16">
    <Newsletter />
  </section>
</Layout>
